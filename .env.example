# ─────────────────────────────────────────────────────────────
#  AI Trading Floor — Backend environment
#  Copy to `.env` and fill in your values:  cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Alpaca brokerage (required) ──────────────────────────────
# Paper-trading credentials from https://app.alpaca.markets/
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true                 # true = paper trading (recommended), false = live

# ── LLM provider (OpenRouter) ────────────────────────────────
# Every trader and the researcher run through OpenRouter, so this single key
# unlocks models from OpenAI, DeepSeek, Google, xAI, etc. No per-provider keys
# are needed. Get one at https://openrouter.ai/keys.
OPENROUTER_API_KEY=your_openrouter_key

# ── Models (OpenRouter "provider/model" IDs) ─────────────────
# USE_MANY_MODELS=false -> every trader uses TRADER_MODEL.
TRADER_MODEL=openai/gpt-4.1-mini
# USE_MANY_MODELS=true  -> the 4 traders use these models in order.
TRADER_MODELS=openai/gpt-4.1-mini,deepseek/deepseek-chat,google/gemini-2.5-flash,x-ai/grok-3-mini-beta
# The Researcher sub-agent (web search + summarizing) — keep this cheap.
# Cheaper options: openai/gpt-4.1-nano, google/gemini-2.5-flash, deepseek/deepseek-chat
RESEARCHER_MODEL=openai/gpt-4.1-mini

# ── Researcher tools ─────────────────────────────────────────
# Web search for the Researcher sub-agent. Choose the provider:
#   SEARCH_PROVIDER=tavily (default) — agent-native, returns extracted content
#   SEARCH_PROVIDER=brave           — independent index, snippet-style results
SEARCH_PROVIDER=tavily
# Tavily (default provider): https://app.tavily.com/
TAVILY_API_KEY=your_tavily_key
# Brave (only needed if SEARCH_PROVIDER=brave): https://brave.com/search/api/
BRAVE_API_KEY=your_brave_search_key

# ── Market data (optional) ───────────────────────────────────
# Without Polygon, share prices fall back to random numbers (simulation only).
# POLYGON_PLAN: "" (end-of-day, default) | "paid" (15-min delayed) | "realtime"
POLYGON_API_KEY=
POLYGON_PLAN=

# ── Push notifications (optional) ────────────────────────────
# Pushover for trade-summary notifications: https://pushover.net/
PUSHOVER_USER=
PUSHOVER_TOKEN=

# ── Trading floor behaviour ──────────────────────────────────
# Scheduling: open_close (default) = run twice/day at the open and before close;
#             interval = legacy fixed-frequency loop using RUN_EVERY_N_MINUTES.
RUN_SCHEDULE=open_close
RUN_ON_START=true                       # run one cycle immediately when the floor is started
OPEN_DELAY_MINUTES=0                     # minutes after the open to run (0 = at the bell)
CLOSE_LEAD_MINUTES=10                   # minutes before the close to run (so orders can fill)
RUN_EVERY_N_MINUTES=60                  # only used when RUN_SCHEDULE=interval
RUN_EVEN_WHEN_MARKET_IS_CLOSED=false    # interval mode only: trade outside market hours
USE_MANY_MODELS=false                   # true = 4 different models, false = all GPT

# ── API / CORS ───────────────────────────────────────────────
# Comma-separated list of allowed frontend origins; "*" allows all (dev only).
FRONTEND_ORIGINS=*
