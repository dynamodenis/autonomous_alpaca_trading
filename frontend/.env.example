# Base URL for the FastAPI backend.
#
# Leave EMPTY for local development: requests go to "/api/*" and Vite's dev
# proxy (see vite.config.ts) forwards them to the backend, avoiding CORS.
#
# For a deployed frontend talking to a remote backend, set the full origin:
#   VITE_API_BASE_URL=https://your-backend.example.com
VITE_API_BASE_URL=http://localhost:8000

# Dashboard poll interval in milliseconds (how often the UI refreshes data).
VITE_POLL_INTERVAL_MS=8000
